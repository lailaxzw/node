<!DOCTYPE html>
<html>

<head>
    <title>Clientes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <%- include('../partials/nav') %>

    <div class="container mt-4">

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">
                    <%= (typeof clienteEditar !== 'undefined' && clienteEditar) ? '✏️ Editar Cliente' : '➕ Novo Cliente' %>
                </h5>
                
                <form action="<%= (typeof clienteEditar !== 'undefined' && clienteEditar) ? '/clientes/editar/' + clienteEditar.id : '/clientes/salvar' %>" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input type="text" name="nome" class="form-control form-control-lg" 
                               value="<%= (typeof clienteEditar !== 'undefined' && clienteEditar) ? clienteEditar.nome : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control form-control-lg" 
                               value="<%= (typeof clienteEditar !== 'undefined' && clienteEditar) ? clienteEditar.email : '' %>" required>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary">
                            <%= (typeof clienteEditar !== 'undefined' && clienteEditar) ? 'Atualizar' : 'Salvar' %>
                        </button>
                        
                        <% if (typeof clienteEditar !== 'undefined' && clienteEditar) { %>
                            <a href="/clientes" class="btn btn-secondary">Cancelar Edição</a>
                        <% } %>
                    </div>

                </form>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">📂 Clientes</h4>
        </div>

        <div class="d-none d-md-block">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th width="150">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(cli => { %>
                        <tr>
                            <td><%= cli.id %></td>
                            <td><%= cli.nome %></td>
                            <td><%= cli.email %></td>
                            <td>
                                <a href="/clientes/editar/<%= cli.id %>" class="btn btn-warning btn-sm">Editar</a>
                                <a href="/clientes/excluir/<%= cli.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir este cliente?')">Excluir</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            <% clientes.forEach(cli => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= cli.nome %></h5>
                        <p class="card-text text-muted mb-1">ID: <%= cli.id %></p>
                        <p class="card-text text-muted mb-3">Email: <%= cli.email %></p>

                        <div class="d-grid gap-2">
                            <a href="/clientes/editar/<%= cli.id %>" class="btn btn-warning btn-sm">✏️ Editar</a>
                            <a href="/clientes/excluir/<%= cli.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir este cliente?')">❌ Excluir</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <a href="/" class="btn btn-secondary w-100 mt-3">Voltar</a>

    </div>

    <%- include('../partials/footer') %>
</body>

</html>