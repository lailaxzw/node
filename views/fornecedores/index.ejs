<!DOCTYPE html>
<html>

<head>
    <title>Fornecedores</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <%- include('../partials/nav') %>

    <div class="container mt-4">

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">
                    <%= (typeof fornecedorEditar !== 'undefined' && fornecedorEditar) ? '✏️ Editar Fornecedor' : '➕ Novo Fornecedor' %>
                </h5>
                
                <form action="<%= (typeof fornecedorEditar !== 'undefined' && fornecedorEditar) ? '/fornecedores/editar/' + fornecedorEditar.id : '/fornecedores/salvar' %>" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input type="text" name="nome" class="form-control form-control-lg" 
                               value="<%= (typeof fornecedorEditar !== 'undefined' && fornecedorEditar) ? fornecedorEditar.nome : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">CNPJ</label>
                        <input type="text" name="cnpj" class="form-control form-control-lg" 
                               value="<%= (typeof fornecedorEditar !== 'undefined' && fornecedorEditar) ? fornecedorEditar.cnpj : '' %>" required>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary">
                            <%= (typeof fornecedorEditar !== 'undefined' && fornecedorEditar) ? 'Atualizar' : 'Salvar' %>
                        </button>
                        
                        <% if (typeof fornecedorEditar !== 'undefined' && fornecedorEditar) { %>
                            <a href="/fornecedores" class="btn btn-secondary">Cancelar Edição</a>
                        <% } %>
                    </div>

                </form>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">📂 Fornecedores</h4>
        </div>

        <div class="d-none d-md-block">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>CNPJ</th>
                        <th width="150">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% fornecedores.forEach(forn => { %>
                        <tr>
                            <td><%= forn.id %></td>
                            <td><%= forn.nome %></td>
                            <td><%= forn.cnpj %></td>
                            <td>
                                <a href="/fornecedores/editar/<%= forn.id %>" class="btn btn-warning btn-sm">Editar</a>
                                <a href="/fornecedores/excluir/<%= forn.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir este fornecedor?')">Excluir</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            <% fornecedores.forEach(forn => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= forn.nome %></h5>
                        <p class="card-text text-muted mb-1">ID: <%= forn.id %></p>
                        <p class="card-text text-muted mb-3">CNPJ: <%= forn.cnpj %></p>

                        <div class="d-grid gap-2">
                            <a href="/fornecedores/editar/<%= forn.id %>" class="btn btn-warning btn-sm">✏️ Editar</a>
                            <a href="/fornecedores/excluir/<%= forn.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir este fornecedor?')">❌ Excluir</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <a href="/" class="btn btn-secondary w-100 mt-3">Voltar</a>

    </div>

    <%- include('../partials/footer') %>
</body>

</html>