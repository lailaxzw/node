<!DOCTYPE html>
<html>

<head>
    <title>Funcionários</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <%- include('../partials/nav') %>

    <div class="container mt-4">

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">
                    <%= typeof funcionarioEditar !== 'undefined' ? '✏️ Editar Funcionário' : '➕ Novo Funcionário' %>
                </h5>
                
                <form action="<%= typeof funcionarioEditar !== 'undefined' ? '/funcionarios/editar/' + funcionarioEditar.id : '/funcionarios/salvar' %>" method="POST">

                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input type="text" name="nome" class="form-control" value="<%= typeof funcionarioEditar !== 'undefined' ? funcionarioEditar.nome : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= typeof funcionarioEditar !== 'undefined' ? funcionarioEditar.email : '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Cargo</label>
                        <input type="text" name="cargo" class="form-control" value="<%= typeof funcionarioEditar !== 'undefined' ? funcionarioEditar.cargo : '' %>" required>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary">Salvar</button>
                        <% if (typeof funcionarioEditar !== 'undefined') { %>
                            <a href="/funcionarios" class="btn btn-light">Cancelar Edição</a>
                        <% } %>
                    </div>

                </form>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">📂 Funcionários</h4>
        </div>

        <div class="d-none d-md-block">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Cargo</th>
                        <th width="150">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% funcionarios.forEach(func => { %>
                        <tr>
                            <td><%= func.id %></td>
                            <td><%= func.nome %></td>
                            <td><%= func.email %></td>
                            <td><%= func.cargo %></td>
                            <td>
                                <a href="/funcionarios/editar/<%= func.id %>" class="btn btn-warning btn-sm">Editar</a>
                                <a href="/funcionarios/excluir/<%= func.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir este funcionário?')">Excluir</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            <% funcionarios.forEach(func => { %>
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><%= func.nome %></h5>
                        <p class="card-text text-muted mb-1">ID: <%= func.id %></p>
                        <p class="card-text mb-1"><strong>Email:</strong> <%= func.email %></p>
                        <p class="card-text mb-3"><strong>Cargo:</strong> <%= func.cargo %></p>

                        <div class="d-grid gap-2">
                            <a href="/funcionarios/editar/<%= func.id %>" class="btn btn-warning btn-sm">✏️ Editar</a>
                            <a href="/funcionarios/excluir/<%= func.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja excluir este funcionário?')">❌ Excluir</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <a href="/" class="btn btn-secondary w-100 mt-3">Voltar</a>

    </div>

    <%- include('../partials/footer') %>
</body>

</html>